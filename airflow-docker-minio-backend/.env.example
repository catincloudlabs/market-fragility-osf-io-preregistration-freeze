# =============================================================================
# OSF PREREGISTRATION DISCLOSURE: ENVIRONMENT SECRETS TEMPLATE
# =============================================================================
# Protocol Reference: 
#   - Section 4.5 (Computational Reproducibility)
#   - Section 4.2 (Data Acquisition)
#
# 1. PROTOCOL ALIGNMENT (Secure Reproducibility):
# Section 4.5 mandates an isolated, reproducible Dockerized environment. To 
# execute the Data Acquisition DAGs (Section 4.2), proprietary API keys for 
# Databento (high-frequency microstructure) and FRED (macroeconomic boundaries) 
# are required. 
#
# 2. ENGINEERING INSTRUCTIONS (For Peer Reviewers):
# To protect proprietary credentials, the actual `.env` file is excluded from 
# this OSF repository. Reviewers wishing to replicate the extraction pipeline 
# must clone this file, rename it to `.env`, and populate it with their own 
# active API keys prior to running `astro dev start`. The Astro CLI will 
# automatically securely inject these secrets into the Airflow containers.
# =============================================================================

# =============================================================================
# TWIN STACK CONFIGURATION (Secrets & Env Vars)
# =============================================================================

# --- 1. SECRETS ---
DATABENTO_API_KEY=<YOUR-DATEBENTO-API-KEY>
NASDAQ_API_KEY=<YOUR-NASDAQ-API-KEY>
FRED_API_KEY=<YOUR-FRED-API-KEY>

# MinIO Credentials
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123

# --- 2. AIRFLOW PERFORMANCE ---
# Prevents "Thundering Herd" API requests that trigger 429 Rate Limits.
AIRFLOW__CORE__PARALLELISM=16

# Ensures you process days sequentially (or in small batches), not 2 weeks at once.
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=3

# Keeps individual DAGs from hogging all system resources.
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=16

AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=30
AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=30
